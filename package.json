{
  "name": "@cloudglab/gerrit-cli",
  "version": "1.0.0",
  "description": "Gerrit CLI and SDK - A modern CLI tool and TypeScript SDK for Gerrit Code Review, built with Effect-TS",
  "keywords": [
    "gerrit",
    "code-review",
    "cli",
    "sdk",
    "effect",
    "effect-ts",
    "typescript",
    "api-client"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "gerrit-cli": "./dist/bin/gerrit-cli.js",
    "gerrit": "./dist/bin/gerrit-cli.js",
    "gerrit-dev": "./dist/bin/gerrit-dev.js",
    "gerrit-reviewer": "./dist/bin/gerrit-reviewer.js",
    "gerrit-lead": "./dist/bin/gerrit-lead.js",
    "gerrit-ci": "./dist/bin/gerrit-ci.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./api": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./services/config": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./services/git-worktree": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schemas/gerrit": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schemas/config": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./utils": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloudglab/gerrit-cli.git"
  },
  "bugs": {
    "url": "https://github.com/cloudglab/gerrit-cli/issues"
  },
  "homepage": "https://github.com/cloudglab/gerrit-cli#readme",
  "files": [
    "CHANGELOG.md",
    "README.md",
    "assets/readme",
    "dist",
    "scripts",
    "skills",
    "tsconfig.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.24.0",
  "devDependencies": {
    "@biomejs/biome": "^2.2.2",
    "@types/node": "^24.3.1",
    "@vitest/coverage-v8": "^4.1.8",
    "ast-grep": "^0.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "msw": "^2.11.1",
    "oxlint": "^1.14.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@effect/platform": "^0.90.10",
    "@effect/platform-node": "^0.94.2",
    "@effect/schema": "^0.75.5",
    "@inquirer/prompts": "^7.8.4",
    "chalk": "^5.6.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.0",
    "effect": "^3.18.4",
    "signal-exit": "3.0.7",
    "turndown": "^7.2.4",
    "undici": "^7.28.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "tsx src/cli/index.ts",
    "build": "tsx scripts/build-dist.ts",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:coverage:check": "tsx scripts/check-coverage.ts",
    "release:smoke-query": "tsx scripts/release-query-smoke.ts --dry-run",
    "release:smoke-query:live": "GERRIT_SMOKE_LIVE=true tsx scripts/release-query-smoke.ts --continue-on-error",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/ tests/",
    "format": "biome format --write src/ tests/",
    "format:check": "biome check src/ tests/",
    "check:all": "tsc --noEmit && oxlint src/ tests/ && biome check src/ tests/ && vitest run --coverage --passWithNoTests && tsx scripts/build-dist.ts"
  }
}

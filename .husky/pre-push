# Husky pre-push hook

# Type checking
echo "Running type check..."
pnpm exec tsc --noEmit

# Run all tests with coverage and check thresholds
echo "Running tests with coverage check..."
pnpm exec tsx scripts/check-coverage.ts

# Run linters and formatter
echo "Running linters..."
pnpm exec oxlint src/ tests/
pnpm exec biome format --write src/ tests/

# Check file sizes
echo "Checking file sizes..."
pnpm exec tsx scripts/check-file-size.ts

# Run ast-grep to check for banned 'as' typecasting
echo "Checking for banned patterns..."
